<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RegistroEstudiantes.MainPage"
             Title=""
             BackgroundColor="#F5F4FF">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- HEADER -->
            <Grid BackgroundColor="#231E5F"
                  Padding="24,36,24,48">
                <VerticalStackLayout Spacing="4">
                    <Label Text="FORMULARIO"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="2"
                           TextColor="#4BBB84"/>
                    <Label Text="Registro de Estudiante"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </VerticalStackLayout>
            </Grid>

            <!-- AVATAR -->
            <VerticalStackLayout HorizontalOptions="Center"
                                 Margin="0,-44,0,8"
                                 Spacing="6">
                <Frame CornerRadius="50"
                       HeightRequest="100"
                       WidthRequest="100"
                       HorizontalOptions="Center"
                       IsClippedToBounds="True"
                       BorderColor="#4BBB84"
                       BackgroundColor="White"
                       Padding="4"
                       HasShadow="False">
                    <Frame CornerRadius="46"
                           IsClippedToBounds="True"
                           BackgroundColor="#EDE8FF"
                           BorderColor="Transparent"
                           Padding="0">
                        <Image x:Name="FotoEstudiante"
                               Source="student_placeholder.png"
                               Aspect="AspectFill"
                               HeightRequest="92"
                               WidthRequest="92"/>
                    </Frame>
                </Frame>

                <Button Text="Seleccionar fotografía"
                        Clicked="OnSeleccionarFotoClicked"
                        BackgroundColor="Transparent"
                        TextColor="#7C3AED"
                        FontSize="12"
                        FontAttributes="Bold"
                        HeightRequest="32"
                        Padding="0"/>
            </VerticalStackLayout>

            <!-- FORMULARIO -->
            <VerticalStackLayout Padding="20,4,20,28" Spacing="0">

                <!-- Matrícula -->
                <Label Text="MATRÍCULA"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="#231E5F"
                       Margin="0,12,0,5"/>
                <Frame BorderColor="#E5E0FF"
                       BackgroundColor="White"
                       CornerRadius="10"
                       Padding="4,0"
                       HasShadow="False">
                    <Entry x:Name="EntryMatricula"
                           Placeholder="Ej. 2021001234"
                           Keyboard="Numeric"
                           PlaceholderColor="#BBB9D8"
                           TextColor="#231E5F"
                           FontSize="14"
                           BackgroundColor="Transparent"/>
                </Frame>

                <!-- Nombre -->
                <Label Text="NOMBRE(S)"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="#231E5F"
                       Margin="0,12,0,5"/>
                <Frame BorderColor="#E5E0FF"
                       BackgroundColor="White"
                       CornerRadius="10"
                       Padding="4,0"
                       HasShadow="False">
                    <Entry x:Name="EntryNombre"
                           Placeholder="Ej. María"
                           PlaceholderColor="#BBB9D8"
                           TextColor="#231E5F"
                           FontSize="14"
                           BackgroundColor="Transparent"/>
                </Frame>

                <!-- Apellidos -->
                <Label Text="APELLIDOS"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="#231E5F"
                       Margin="0,12,0,5"/>
                <Frame BorderColor="#E5E0FF"
                       BackgroundColor="White"
                       CornerRadius="10"
                       Padding="4,0"
                       HasShadow="False">
                    <Entry x:Name="EntryApellidos"
                           Placeholder="Ej. García López"
                           PlaceholderColor="#BBB9D8"
                           TextColor="#231E5F"
                           FontSize="14"
                           BackgroundColor="Transparent"/>
                </Frame>

                <!-- Sexo -->
                <Label Text="SEXO"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="#231E5F"
                       Margin="0,12,0,5"/>
                <Frame BorderColor="#E5E0FF"
                       BackgroundColor="White"
                       CornerRadius="10"
                       Padding="4,0"
                       HasShadow="False">
                    <Picker x:Name="PickerSexo"
                            Title="-- Selecciona --"
                            TitleColor="#BBB9D8"
                            TextColor="#231E5F"
                            FontSize="14"
                            BackgroundColor="Transparent">
                        <Picker.Items>
                            <x:String>Masculino</x:String>
                            <x:String>Femenino</x:String>
                            <x:String>Prefiero no decir</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>

                <!-- Botones -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      Margin="0,20,0,0">
                    <Button Grid.Column="0"
                            Text="Guardar"
                            Clicked="OnGuardarClicked"
                            BackgroundColor="#4BBB84"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="50"/>
                    <Button Grid.Column="1"
                            Text="Limpiar"
                            Clicked="OnLimpiarClicked"
                            BackgroundColor="Transparent"
                            TextColor="#7C3AED"
                            FontAttributes="Bold"
                            FontSize="14"
                            CornerRadius="12"
                            HeightRequest="50"
                            BorderColor="#7C3AED"
                            BorderWidth="1.5"/>
                </Grid>

                <!-- Tarjeta resultado -->
                <Frame x:Name="FrameResultado"
                       IsVisible="False"
                       BackgroundColor="White"
                       BorderColor="#4BBB84"
                       CornerRadius="12"
                       Padding="16"
                       HasShadow="False"
                       Margin="0,16,0,0">
                    <VerticalStackLayout Spacing="8">
                        <StackLayout Orientation="Horizontal"
                                     Spacing="8">
                            <BoxView WidthRequest="7"
                                     HeightRequest="7"
                                     CornerRadius="4"
                                     BackgroundColor="#4BBB84"
                                     VerticalOptions="Center"/>
                            <Label Text="DATOS GUARDADOS"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1"
                                   TextColor="#4BBB84"/>
                        </StackLayout>
                        <Label x:Name="LabelResultado"
                               TextColor="#231E5F"
                               FontSize="13"
                               LineHeight="1.5"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>